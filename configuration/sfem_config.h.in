#ifndef SFEM_CONFIG_HPP
#define SFEM_CONFIG_HPP

#cmakedefine SFEM_ENABLE_AMG
#cmakedefine SFEM_ENABLE_AVX2
#cmakedefine SFEM_ENABLE_AVX512
#cmakedefine SFEM_ENABLE_BLAS
#cmakedefine SFEM_ENABLE_CUBLAS
#cmakedefine SFEM_ENABLE_CUDA
#cmakedefine SFEM_ENABLE_CUSPARSE
#cmakedefine SFEM_ENABLE_EXPLICIT_VECTORIZATION
#cmakedefine SFEM_ENABLE_HXTSORT
#cmakedefine SFEM_ENABLE_LAPACK
#cmakedefine SFEM_ENABLE_MEM_DIAGNOSTICS
#cmakedefine SFEM_ENABLE_METIS
#cmakedefine SFEM_ENABLE_OPENMP
#cmakedefine SFEM_ENABLE_RYAML
#cmakedefine SFEM_ENABLE_TRACE
#cmakedefine SFEM_USE_OCCUPANCY_MAX_POTENTIAL
#cmakedefine SFEM_ENABLE_MPI
#cmakedefine SFEM_ENABLE_AVX512_SORT
#cmakedefine SFEM_ENABLE_SCCD
#cmakedefine SFEM_ENABLE_SSDF
#cmakedefine SFEM_ENABLE_SRESAMPLE


#cmakedefine01 SFEM_PRINT_THROUGHPUT

#ifdef SFEM_ENABLE_CUDA
#define SFEM_CUDA_ARCH @SFEM_CUDA_ARCH@
#endif

#define CUDA_UNIFIED_MEMORY 0
#define CUDA_MANAGED_MEMORY 1
#define CUDA_HOST_MEMORY 2

#include "smesh_config.hpp"

#include <stdint.h>
#include <stdlib.h>

// -----------------------------
// Floating point representation
// -----------------------------

// geometric quantities / mesh
typedef smesh::geom_t geom_t;
#define SFEM_MPI_GEOM_T SMESH_MPI_GEOM_T
#define SFEM_CUSPARSE_GEOM_T SMESH_CUSPARSE_GEOM_T

// real numbers
typedef smesh::real_t real_t;
#define SFEM_MPI_REAL_T SMESH_MPI_REAL_T
#define SFEM_CUSPARSE_REAL_T SMESH_CUSPARSE_REAL_T
#define SFEM_REAL_T_IS_FLOAT64 SMESH_REAL_T_IS_FLOAT64
#define SFEM_REAL_T_IS_FLOAT32 SMESH_REAL_T_IS_FLOAT32

// computation real numbers and explicit vectorized types
typedef smesh::scalar_t scalar_t;
#define SFEM_MPI_SCALAR_T SMESH_MPI_SCALAR_T
#define SFEM_CUSPARSE_SCALAR_T SMESH_CUSPARSE_SCALAR_T

#ifndef _WIN32
#define SFEM_VEC_SIZE SMESH_VEC_SIZE
typedef smesh::vec_t vec_t;
#else
#define SFEM_VEC_SIZE 1
typedef scalar_t vec_t;
#endif
// Jacobian
typedef smesh::jacobian_t jacobian_t;
#define SFEM_MPI_JACOBIAN_CPU_T SMESH_MPI_JACOBIAN_CPU_T
#define SFEM_CUSPARSE_JACOBIAN_CPU_T SMESH_CUSPARSE_JACOBIAN_CPU_T

// Jacobian (GPU)

// Accumulator for local kernels (before local to global)
typedef smesh::accumulator_t accumulator_t;
#define SFEM_MPI_ACCUMULATOR_T SMESH_MPI_ACCUMULATOR_T
#define SFEM_CUSPARSE_ACCUMULATOR_T SMESH_CUSPARSE_ACCUMULATOR_T

// -----------------------------
// Indexing representation
// -----------------------------

// node / dof indices
typedef smesh::idx_t idx_t;
#define SFEM_MPI_IDX_T SMESH_MPI_IDX_T
#define SFEM_CUSPARSE_IDX_T SMESH_CUSPARSE_IDX_T
#define SFEM_IDX_INVALID SMESH_IDX_INVALID

// nnz count
typedef smesh::count_t count_t;
#define SFEM_MPI_COUNT_T SMESH_MPI_COUNT_T
#define SFEM_CUSPARSE_COUNT_T SMESH_CUSPARSE_COUNT_T
#define SFEM_COUNT_INVALID SMESH_COUNT_INVALID

// element ids
typedef smesh::element_idx_t element_idx_t;
#define SFEM_MPI_ELEMENT_IDX_T SMESH_MPI_ELEMENT_IDX_T
#define SFEM_CUSPARSE_ELEMENT_IDX_T SMESH_CUSPARSE_ELEMENT_IDX_T
#define SFEM_ELEMENT_IDX_INVALID SMESH_ELEMENT_IDX_INVALID

// Local ids for small block of elements (goal is 16 bits with max id 65'536)
typedef smesh::local_idx_t local_idx_t;
#define SFEM_MPI_LOCAL_IDX_T SMESH_MPI_LOCAL_IDX_T
#define SFEM_CUSPARSE_LOCAL_IDX_T SMESH_CUSPARSE_LOCAL_IDX_T
#define SFEM_LOCAL_IDX_INVALID SMESH_LOCAL_IDX_INVALID

// -----------------------------
// Other types
#define SFEM_TET4_CUDA @SFEM_TET4_CUDA@
#define SFEM_TET10_CUDA @SFEM_TET10_CUDA@
#define SFEM_TET10_WENO @SFEM_TET10_WENO@

#define SFEM_CUDA_MEMORY_MODEL @SFEM_CUDA_MEMORY_MODEL@

#define SFEM_LOG_LEVEL @SFEM_LOG_LEVEL@

#define SFEM_WARP_SIZE 32
#define SFEM_WARP_FULL_MASK 0xffffffff

#ifdef SFEM_ENABLE_CUDA

// To enable atomicOr we need int
typedef int mask_t;
#define SFEM_MPI_MASK_T MPI_INT
#define SFEM_PTRDIFF_INVALID -1

#else

typedef char mask_t;
#define SFEM_MPI_MASK_T MPI_CHAR
#define SFEM_PTRDIFF_INVALID -1

#endif  // SFEM_ENABLE_CUDA

#if defined(__APPLE__)
typedef __fp16 half_t;
#else
typedef _Float16 half_t;
#endif

static const half_t FP16_MAX = (half_t)65504.0f;

typedef float metric_tensor_t;

typedef int64_t  sshex_side_code_t;
typedef uint16_t block_idx_t;
typedef float    scaling_t;
typedef half_t   compressed_t;

#endif  // SFEM_CONFIG_HPP
